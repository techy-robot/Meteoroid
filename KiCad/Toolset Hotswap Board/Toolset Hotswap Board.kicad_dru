(version 1)

(rule ignore_gnd_on_usb_c
	(condition "A.memberOfFootprint('Connector_USB:USB_C_Receptacle_G-Switch_GT-USB-7010ASV')")
	(constraint min_resolved_spokes 0))

(rule ignore_min_hole_on_usb_c
	(condition "A.memberOfFootprint('Connector_USB:USB_C_Receptacle_G-Switch_GT-USB-7010ASV')")
	(constraint hole_clearance (min 0.1mm))
)